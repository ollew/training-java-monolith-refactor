%% Architecture diagram (Mermaid)
%% Shows target services, platform, data flow, and links to substitution-audit concerns
graph LR
  %% Use quoted multiline labels to avoid parser issues
  subgraph PLATFORM [Platform / Runtime]
    K8s["Kubernetes - Managed Containers\nConfig, Secrets, Observability"]
    Auth["Auth (OIDC) / API Gateway"]
    Observability["Metrics & Tracing (Prometheus, OTEL)"]
  end

  subgraph SERVICES [Modernized Services]
    UI["API Gateway / UI\n(replaces JSP scriptlets)"]
    Users["Users Service\n(unique email validation)"]
    Customers["Customers Service\n(prevent delete if dependent hours)"]
    Billing["Billing Service\n(revenue calc, BigDecimal)"]
    Reporting["Reporting Service\n(reports API replaces direct SQL in JSP)"]
    DataAccess["Data-access module\n(shared DAOs & migration helpers)"]
  end

  DB["Managed RDBMS (Postgres or managed)\n(schema via Flyway)"]
  Legacy["Legacy Monolith\n(Embedded Derby, JSPs, inline DDL)"]

  %% Flows
  UI -->|HTTP| Users
  UI -->|HTTP| Customers
  UI -->|HTTP| Billing
  UI -->|HTTP| Reporting

  Users -->|JDBC/ORM| DB
  Customers -->|JDBC/ORM| DB
  Billing -->|JDBC/ORM| DB
  Reporting -->|JDBC/Read-optimized| DB
  DataAccess -->|DB bridge| DB

  Legacy -->|Strangler proxies / dual-write| DataAccess
  Legacy -->|Gradual replace| UI

  Auth --> UI
  Auth --> Users
  Platform -->|provides| K8s
  K8s -->|manages| Services
  Observability -->|collects| Services

  %% Annotations linking to substitution-audit topics
  classDef note fill:#fff7d6,stroke:#e6b800
  class DB,Legacy note
